{
  "compilerOptions": {
    "baseUrl": "./",
    "declaration": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable",
      "ScriptHost"
    ],
    "module": "ES2022",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": true,
    "target": "ES2017",
    "types": [
      "node"
    ],
    "useDefineForClassFields": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
